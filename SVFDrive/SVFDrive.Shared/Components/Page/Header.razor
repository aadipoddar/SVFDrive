<MudBlazor.MudHotkey Key=JsKey.KeyD KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateToHome" />
<MudBlazor.MudHotkey Key=JsKey.KeyL KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="Logout" />

<div class="page-header">
	<div class="header-left">
		<button type="button" class="header-logo-button" title="Go to Home (Ctrl+D)" @onclick="NavigateToHome">
			<img src="images/logo.png" alt="SVF" class="header-logo" />
		</button>
		@if (LeftContent != null)
		{
			@LeftContent
		}
	</div>
	<div class="header-center">
		<h1 class="page-title">@Title</h1>
	</div>
	<div class="header-right">
		@if (RightContent != null)
		{
			@RightContent
		}
		<div class="header-divider"></div>
		<button type="button" class="user-name user-name-button" title="Logout (Ctrl+L)" @onclick="Logout">
			<span class="user-name-desktop">@_user?.Name</span>
			<span class="user-name-mobile">@GetMobileUserName()</span>
		</button>
	</div>
</div>

<style>
	/* Professional Header Section */
	.page-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: #ffffff;
		border-bottom: 1px solid #e2e8f0;
		padding: 10px 24px;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 16px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
		min-height: 52px;
	}

	.header-left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.header-logo {
		width: 40px;
		height: 32px;
		flex-shrink: 0;
	}

	.header-logo-button {
		border: none;
		background: transparent;
		padding: 0;
		display: flex;
		align-items: center;
		cursor: pointer;
	}

	.header-divider {
		width: 1px;
		height: 24px;
		background: #e2e8f0;
		flex-shrink: 0;
	}

	.header-center {
		text-align: center;
	}

	.page-title {
		font-size: 17px;
		font-weight: 600;
		color: #0f172a;
		margin: 0;
		letter-spacing: -0.2px;
	}

	.header-right {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 6px;
	}

	.user-name {
		font-size: 13px;
		font-weight: 500;
		color: #0f172a;
		padding: 6px 10px;
		background: #f8fafc;
		border-radius: 6px;
		border: 1px solid #e2e8f0;
	}

	.user-name-button {
		cursor: pointer;
		font-family: inherit;
		line-height: 1;
	}

	.user-name-mobile {
		display: none;
	}

	@@media (max-width: 768px) {

		.header-divider {
			display: none;
		}

		.user-name {
			display: inline-flex;
			align-items: center;
			padding: 6px 8px;
			font-size: 12px;
		}

		.user-name-desktop {
			display: none;
		}

		.user-name-mobile {
			display: inline;
		}
	}
</style>
