<SfDialog @ref="_dialog" Width="400px" IsModal="true" ShowCloseIcon="true" @bind-Visible="_isVisible" CssClass="confirm-dialog">

	<MudBlazor.MudHotkey Key=JsKey.Enter OnHotkeyPressed="HandleConfirm" />
	<MudBlazor.MudHotkey Key=JsKey.Escape OnHotkeyPressed="HandleCancel" />

	<DialogTemplates>
		<Header>
			<div class="cd-header">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
					 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					 style="color: #2563eb;">
					<path d="M12 20h9" />
					<path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
				</svg>
				<span>@(string.IsNullOrWhiteSpace(CurrentName) ? "New" : "Edit")</span>
			</div>
		</Header>
		<Content>
			<div class="cd-body">
				@if (!string.IsNullOrWhiteSpace(CurrentName))
				{
					<div class="cd-detail">
						<span class="cd-detail-label">Current:</span>
						<span class="cd-detail-value">@CurrentName</span>
					</div>
				}
				<label class="cd-input-label">Name</label>
				<SfTextBox @bind-Value="Value" Placeholder="Enter Name" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
				<div class="cd-actions">
					<button class="cd-btn cd-btn-cancel" @onclick="HandleCancel">Cancel</button>
					<button class="cd-btn cd-btn-primary" @onclick="HandleConfirm">Save</button>
				</div>
			</div>
		</Content>
	</DialogTemplates>
</SfDialog>
