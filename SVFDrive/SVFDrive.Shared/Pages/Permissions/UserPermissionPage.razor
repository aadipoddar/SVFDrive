@attribute [Route(PageRouteNames.UserPermission)]

@using SVFDriveLibrary.Models.Operations
@using SVFDriveLibrary.Models.Permissions

<PageTitle>User Permission - SVF Drive</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedItem" />

@if (_isLoading || _loggedInUser is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="User Permission">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel" Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem" Disabled="@_isProcessing" />
								<MenuItem Text="Delete (Del)" IconCss="e-icons e-trash" Id="DeleteSelectedItem" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">User Folder Permission Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">

						<!-- User -->
						<div class="form-field">
							<AutoCompleteWithAdd TItem="UserModel" TValue="UserModel"
												 @ref="_sfFirstFocus"
												 @bind-Value="_selectedUser"
												 DataSource="@_users"
												 Placeholder="Select User"
												 Label="User" Required="true"
												 FieldValue="@nameof(UserModel.Name)"
												 AddNewRoute="@PageRouteNames.User" />
						</div>

						<div class="form-field">
							<label class="field-label">Path <span class="required">*</span></label>
							<SfTextBox @bind-Value="_userPermission.Path" Placeholder="Enter path" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<div class="form-field">
							<label class="field-label">Is File</label>
							<div class="checkbox-wrapper">
								<SfCheckBox @bind-Checked="_userPermission.IsFile" Label="Is File" CssClass="custom-checkbox" />
							</div>
						</div>

						<div class="form-field">
							<label class="field-label">Deny</label>
							<div class="checkbox-wrapper">
								<SfCheckBox @bind-Checked="_userPermission.Deny" Label="Deny" CssClass="custom-checkbox" />
							</div>
						</div>

						<div class="form-field">
							<label class="field-label">Write Permission</label>
							<div class="checkbox-wrapper">
								<SfCheckBox @bind-Checked="_userPermission.Write" Label="Write" CssClass="custom-checkbox" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Users List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_userPermissions" AllowPaging="true" AllowSorting="true" AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">

						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="UserPermissionModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridColumns>
							<GridColumn Field="@nameof(UserPermissionModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="User" HeaderText="User" Width="220">
								<Template>
									@{
										var item = (context as UserPermissionModel);
										var user = _users.FirstOrDefault(u => u.Id == item.UserId);
										<span>@user?.Name</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserPermissionModel.Path)" HeaderText="Path" Width="220" />
							<GridColumn Field="@nameof(UserPermissionModel.IsFile)" HeaderText="Is File" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserPermissionModel);
										<span class="@(item.IsFile ? "grid-credit" : "grid-debit")">@(item.IsFile ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserPermissionModel.Deny)" HeaderText="Deny" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserPermissionModel);
										<span class="@(item.Deny ? "grid-credit" : "grid-debit")">@(item.Deny ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserPermissionModel.Write)" HeaderText="Write" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserPermissionModel);
										<span class="@(item.Write ? "grid-credit" : "grid-debit")">@(item.Write ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" IdentifierValue="@_deleteTransactionName"
						  OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<ToastNotification @ref="_toastNotification" />
